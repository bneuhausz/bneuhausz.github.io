---
import { getCollection } from 'astro:content';
import BlogCard from '../../components/BlogCard.astro';
import { BlogFiltersComponent } from '../../components/angular/BlogFilters.component.ts';
import SiteLayout from '../../layouts/SiteLayout.astro';

type BlogPostSummary = {
  slug: string;
  title: string;
  description: string;
  icon: string;
  iconDescription: string;
  tags: string[];
  date: string;
};

const BlogFilters = BlogFiltersComponent as unknown as (props: {
  posts: BlogPostSummary[];
  'data-analog-id'?: string;
}) => unknown;

const posts = await getCollection('posts', ({ data }) => !data.draft);

const formatDate = (dateValue: string | Date) => {
  const parsed = new Date(dateValue);
  return Number.isNaN(parsed.getTime()) ? String(dateValue) : parsed.toISOString().slice(0, 10);
};

const sortedPosts = [...posts].sort((a, b) => {
  const dateA = new Date(a.data.date).getTime();
  const dateB = new Date(b.data.date).getTime();
  return dateB - dateA;
});

const featuredPosts = sortedPosts.slice(0, 3);

const postsForClient = sortedPosts.map((post) => ({
  slug: post.data.slug,
  title: post.data.title,
  description: post.data.description,
  icon: post.data.icon,
  iconDescription: post.data.iconDescription,
  tags: post.data.tags,
  date: formatDate(post.data.date),
}));
---

<SiteLayout title="Blog - bneuhausz.dev" description="Technical notes and tutorials by Bálint Neuhausz" canonical="https://bneuhausz.dev/blog">
  <h1>
    Some of my thoughts are documented here
  </h1>

  <section class="grid gap-8 grid-cols-[repeat(auto-fit,minmax(400px,1fr))] place-items-center py-5">
    {featuredPosts.map((post) => (
      <BlogCard
        post={{
          title: post.data.title,
          slug: post.data.slug,
          description: post.data.description,
          thumbnail: post.data.thumbnail,
          thumbnailDescription: post.data.thumbnailDescription,
          tags: post.data.tags,
          date: formatDate(post.data.date),
          shadowColor: post.data.shadowColor,
        }}
      />
    ))}
  </section>

  <BlogFilters client:visible posts={postsForClient} data-analog-id="blog-filters" />
</SiteLayout>
